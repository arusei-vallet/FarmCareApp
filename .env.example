# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Storage
EXPO_PUBLIC_SUPABASE_PRODUCTS_BUCKET=products

# M-Pesa Daraja API Configuration
# Get these from https://developer.safaricom.co.ke/
# 1. Create an account on Safaricom Daraja Developer Portal
# 2. Create a new app to get Consumer Key and Secret
# 3. For sandbox: Use test credentials provided by Daraja
# 4. For production: Use your actual Paybill/Till credentials

# Consumer Key from Daraja Portal
MPESA_CONSUMER_KEY=your_mpesa_consumer_key

# Consumer Secret from Daraja Portal  
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret

# Paybill Number (Lipa Na M-Pesa)
# Sandbox: Use test shortcode provided by Daraja (usually 174379)
# Production: Your actual Paybill number
MPESA_SHORTCODE=174379

# Passkey
# Sandbox: Provided in Daraja portal under credentials
# Production: Generated when you go live
MPESA_PASSKEY=your_mpesa_passkey

# Environment: 'sandbox' for testing, 'production' for live
MPESA_ENVIRONMENT=sandbox

# Callback URL - This MUST be publicly accessible
# For Supabase Edge Functions, use: https://<your-project-ref>.supabase.co/functions/v1/mpesa-callback
# Replace <your-project-ref> with your actual Supabase project reference
MPESA_CALLBACK_URL=https://your-project-ref.supabase.co/functions/v1/mpesa-callback

# App Configuration
EXPO_PUBLIC_APP_NAME=FarmCare
EXPO_PUBLIC_VERSION=1.0.0
