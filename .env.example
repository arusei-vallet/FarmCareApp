# Supabase Configuration
# Copy this file to .env and fill in your actual values

EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Storage
EXPO_PUBLIC_SUPABASE_PRODUCTS_BUCKET=products

# M-Pesa Daraja API Configuration
# Get these from https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_mpesa_paybill_or_till
MPESA_PASSKEY=your_mpesa_passkey
MPESA_ENVIRONMENT=sandbox  # Use 'sandbox' for testing, 'production' for live
MPESA_CALLBACK_URL=https://your-project.supabase.co/functions/v1/mpesa-callback

# App Configuration
EXPO_PUBLIC_APP_NAME=FarmCare
EXPO_PUBLIC_VERSION=1.0.0
